{
    "extends":"@repo/typescript-config/base.json",
    "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2023",
    "strict": true,
    "esModuleInterop": true,
    // "ignoreDeprecations": "6.0"
    "rootDir": "src",
    "outDir": "dist",

    "declaration": true,
    "declarationMap": true,

    "sourceMap": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}